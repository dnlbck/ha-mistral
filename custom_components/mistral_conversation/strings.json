    "tts": {
      "entry_type": "Text-to-speech",
      "initiate_flow": {
        "reconfigure": "Reconfigure text-to-speech service",
        "user": "Add text-to-speech service"
      },
      "step": {
        "init": {
          "title": "Mistral Text-to-Speech",
          "description": "Set up Voxtral TTS.",
          "data": {
            "name": "Name",
            "tts_voice": "Voice ID"
          },
          "data_description": {
            "tts_voice": "The voice ID to use (e.g., 'jessica'). Leave empty for default."
          }
        }
      },
      "abort": {
        "entry_not_loaded": "Cannot configure while the entry is disabled.",
        "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]"
      }
    }
