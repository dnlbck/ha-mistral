      },
      "step": {
        "init": {
          "title": "Mistral AI Task",
          "description": "Set up this AI task agent.",
          "data": {
            "name": "Name",
            "recommended": "Use recommended model settings"
          }
        },
        "advanced": {
          "title": "Advanced Settings",
          "description": "Fine-tune the model parameters.",
          "data": {
            "chat_model": "Model",
            "max_tokens": "Maximum tokens",
            "top_p": "Top P",
            "temperature": "Temperature",
            "safe_prompt": "Safe prompt"
          },
          "data_description": {
            "chat_model": "Model for AI tasks.",
            "max_tokens": "Max tokens in the response.",
            "top_p": "Nucleus sampling (0–1).",
            "temperature": "Randomness (0–1.5). Lower = more deterministic.",
            "safe_prompt": "Enable Mistral’s built-in safety guardrails."
          }
        }
      },
      "abort": {
        "entry_not_loaded": "Cannot configure while the entry is disabled.",
        "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]"
      }
    },
    "stt": {
      "entry_type": "Speech-to-text",
      "initiate_flow": {
        "reconfigure": "Reconfigure speech-to-text service",
        "user": "Add speech-to-text service"
      },
      "step": {
        "init": {
          "title": "Mistral Speech-to-Text",
          "description": "Set up Voxtral STT.",
          "data": {
            "name": "Name",
            "prompt": "Context prompt",
            "chat_model": "Model"
          },
          "data_description": {
            "prompt": "Optional context to aid transcription accuracy (e.g., domain-specific terms).",
