          "description": "The Mistral config entry to use."
        },
        "prompt": {
          "name": "Prompt",
          "description": "The prompt to send to Mistral."
        }
      }
    }
  },
  "exceptions": {
    "invalid_config_entry": {
      "message": "Invalid config entry: {config_entry}"
